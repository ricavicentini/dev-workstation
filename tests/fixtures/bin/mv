#!/usr/bin/env bash

set -uo pipefail

if [[ "${SYMLINK_TEST_MV_MODE:-}" != 'term-after-first' ]]; then
  exec "${SYMLINK_TEST_REAL_MV:?}" "$@"
fi

count=0
if [[ -f "${SYMLINK_TEST_MV_COUNT_FILE:?}" ]]; then
  read -r count < "$SYMLINK_TEST_MV_COUNT_FILE"
fi

count=$((count + 1))
printf '%s\n' "$count" > "$SYMLINK_TEST_MV_COUNT_FILE"
"${SYMLINK_TEST_REAL_MV:?}" "$@"

if [[ "$count" -eq 1 ]]; then
  kill -TERM "$PPID"
  exit 143
fi
