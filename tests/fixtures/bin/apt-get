#!/bin/bash

set -uo pipefail

case "${1:-}" in
  update)
    printf '%s\n' 'apt-get update' >> "${HOMEBREW_TEST_APT_LOG:?}"
    ;;
  install)
    if [[ "${2:-}" != '-y' ]]; then
      exit 64
    fi
    if [[ "${3:-}" == 'zsh' ]]; then
      printf '%s\n' 'apt-get install -y zsh' >> "${ZSH_TEST_APT_LOG:?}"
      printf '#!/bin/bash\nexit 0\n' > "${ZSH_TEST_FAKE_ZSH:?}"
      /bin/chmod +x "$ZSH_TEST_FAKE_ZSH"
    elif [[ "${3:-}" == 'build-essential' && "${4:-}" == 'procps' && "${5:-}" == 'curl' && "${6:-}" == 'file' && "${7:-}" == 'git' ]]; then
      printf '%s\n' 'apt-get install -y build-essential procps curl file git' >> "${HOMEBREW_TEST_APT_LOG:?}"
    else
      exit 64
    fi
    ;;
  *)
    exit 64
    ;;
esac
